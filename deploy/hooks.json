[
  {
    "id": "codeoutbox-deploy",
    "execute-command": "/opt/codeoutbox/deploy/deploy.sh",
    "command-working-directory": "/opt/codeoutbox",
    "response-message": "deploying",
    "trigger-rule": {
      "and": [
        {
          "match": {
            "type": "payload-hmac-sha256",
            "secret": "{{ getenv `CODEOUTBOX_WEBHOOK_SECRET` }}",
            "parameter": { "source": "header", "name": "X-Hub-Signature-256" }
          }
        },
        {
          "match": {
            "type": "value",
            "value": "refs/heads/main",
            "parameter": { "source": "payload", "name": "ref" }
          }
        }
      ]
    }
  }
]
