{
  "_comment": "Copy to .mcp.json and set CO_TOKEN. Requires the CodeOutbox server running (npm run start / docker compose up). CO_TOKEN is an API token: create one with `CO_TOKEN=<session> npm run co -- token create`.",
  "mcpServers": {
    "codeoutbox": {
      "command": "npx",
      "args": ["tsx", "src/mcp.ts"],
      "env": {
        "CO_URL": "http://localhost:3000",
        "CO_TOKEN": "REPLACE_WITH_YOUR_SESSION_TOKEN"
      }
    }
  }
}
