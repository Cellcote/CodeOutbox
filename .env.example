# Copy to .env and adjust. All values have sane defaults for local dev.

# HTTP
PORT=3000
BASE_URL=http://localhost:3000

# Tokens (CHANGE THIS in production)
TOKEN_SECRET=dev-secret-change-me

# Database
#   - In Docker/production: set DATABASE_URL and the driver is "pg" (real Postgres).
#   - Locally with nothing set: driver falls back to embedded PGlite (no server needed).
# DATABASE_URL=postgres://codeoutbox:codeoutbox@localhost:5432/codeoutbox
# DB_DRIVER=pg            # force "pg" or "pglite"
# PGLITE_DIR=./.data/pglite

# Email transport: "console" (prints to stdout) or "smtp"
EMAIL_TRANSPORT=console
MAIL_FROM=CodeOutbox <noreply@mail.codeoutbox.com>
# SMTP_URL=smtp://user:pass@smtp.example.com:587

# Sending / domains
# FREE_TIER_SEND_LIMIT=100        # above this recipient count, a verified domain is required
# DOMAIN_VERIFY_MODE=dns          # "dns" (real TXT lookups) or "mock" (assume published; dev only)
# SPF_INCLUDE=spf.codeoutbox.com
# DMARC_RUA=dmarc@codeoutbox.com

# Warmup: cap daily sends on a ramp while the IP is new (default on)
# WARMUP_ENABLED=true

# Stripe billing (optional — unset STRIPE_SECRET_KEY disables billing)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_GROWTH=price_...
# STRIPE_PRICE_SCALE=price_...
# STRIPE_PRICE_BUSINESS=price_...
# STRIPE_PRICE_MAX=price_...
# Annual prices (10% off) — optional; fall back to monthly if unset:
# STRIPE_PRICE_PRO_ANNUAL=price_...
# STRIPE_PRICE_GROWTH_ANNUAL=price_...
# STRIPE_PRICE_SCALE_ANNUAL=price_...
# STRIPE_PRICE_BUSINESS_ANNUAL=price_...
# STRIPE_PRICE_MAX_ANNUAL=price_...
