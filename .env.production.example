# Copy to .env on the LXC and fill in. Never commit the real .env.

# --- public URL: confirm / claim / unsubscribe links use this. MUST be the
#     externally reachable URL of the APP host (NPM/TLS), or links will break.
#     The apex serves the static marketing site; the app runs on a subdomain. ---
BASE_URL=https://demo.codeoutbox.com
PORT=3000

# --- secrets ---
# generate: openssl rand -hex 32
TOKEN_SECRET=CHANGE_ME_long_random_hex

# --- database (internal to the compose network; do not expose 5432) ---
POSTGRES_USER=codeoutbox
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=codeoutbox
DB_DRIVER=pg
DATABASE_URL=postgres://codeoutbox:CHANGE_ME_db_password@db:5432/codeoutbox

# --- email via Resend (SMTP relay) ---
# Resend: username is literally "resend"; password is your API key (re_...).
# Verify your sending domain in the Resend dashboard and set MAIL_FROM to it.
EMAIL_TRANSPORT=smtp
SMTP_URL=smtps://resend:re_YOUR_RESEND_API_KEY@smtp.resend.com:465
MAIL_FROM=CodeOutbox <hello@your-verified-domain.com>

# --- plans / limits ---
# Free-tier plan caps (override for staging/testing; real defaults are 1000 / 3000).
# FREE_SUBSCRIBERS=1000
# FREE_SENDS=3000

# --- sending / domains ---
FREE_TIER_SEND_LIMIT=100
DOMAIN_VERIFY_MODE=dns
# Bounce/complaint loop (set once the MTA pipes bounces to /webhooks/email-event)
# BOUNCE_DOMAIN=bounce.codeoutbox.com
# BOUNCE_WEBHOOK_SECRET=CHANGE_ME_long_random_hex

# --- shared sending identity (set ONCE you run your own sending domain / MTA) ---
# Until these are set, broadcasts fall back to MAIL_FROM (works with an ESP relay).
# With them set, tenants without a verified domain send from t<id>@<SHARED_FROM_DOMAIN>,
# DKIM-signed with the shared key. Generate: openssl genrsa 2048
# SHARED_FROM_DOMAIN=mail.codeoutbox.com
# SHARED_DKIM_SELECTOR=co
# SHARED_DKIM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
